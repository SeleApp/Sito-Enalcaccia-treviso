{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/router.ts": {
      "maxDuration": 15
    },
    "api/system-health.ts": {
      "maxDuration": 10
    },
    "api/db-health.ts": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/system-health"
    },
    {
      "src": "/api/db-health",
      "dest": "/api/db-health"
    },
    {
      "src": "/api(?:/(.*))?",
      "dest": "/api/router?path=$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/router?route=sitemap"
    },
    {
      "src": "/feed.xml",
      "dest": "/api/router?route=feed"
    },
    {
      "src": "/rss.xml",
      "dest": "/api/router?route=rss"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
